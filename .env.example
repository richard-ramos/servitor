TELEGRAM_BOT_TOKEN=
CODEX_AUTH_MODE=chatgpt
CODEX_HOST_AUTH_DIR=~/.codex
CODEX_AUTH_REFRESH_INTERVAL_SECONDS=300
# Only required when CODEX_AUTH_MODE=api_key.
OPENAI_API_KEY=
OPENAI_PROXY_HOST=127.0.0.1
OPENAI_PROXY_PORT=3021
OPENAI_PROXY_CLIENT_TOKEN=
OPENAI_UPSTREAM_BASE_URL=https://api.openai.com/v1
CHATGPT_CODEX_UPSTREAM_BASE_URL=https://chatgpt.com/backend-api/codex
DEFAULT_CODEX_MODEL=gpt-5.4-mini
DEFAULT_REASONING_EFFORT=medium
DATA_DIR=./data
ADMIN_USER_IDS=
MAX_CONCURRENT_CONTAINERS=3
MAX_RUN_SECONDS=1800
MAX_OUTPUT_BYTES=200000
MAX_HISTORY_MESSAGES=20
MAX_ATTACHMENT_BYTES=25000000
PROGRESS_UPDATES=false
PROGRESS_INTERVAL_SECONDS=300
AGENT_MESSAGES_ENABLED=true
AGENT_MESSAGE_MAX_PER_RUN=5
AGENT_MESSAGE_MAX_CHARS=1000
AGENT_MESSAGE_POLL_INTERVAL_MS=500
SERVICE_TIMEZONE=UTC
CONTAINER_IMAGE=servitor-agent:latest
SERVITOR_SKIP_DOCKER_BUILD=false
