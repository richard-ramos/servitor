FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git build-essential jq nodejs npm python3 \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex

RUN useradd -m -s /bin/bash agent

COPY scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
COPY scripts/servitor-send /usr/local/bin/servitor-send
COPY scripts/servitor-send-file /usr/local/bin/servitor-send-file
COPY scripts/servitor-action /usr/local/bin/servitor-action
RUN chmod 0755 /usr/local/bin/agent-entrypoint.sh /usr/local/bin/servitor-send /usr/local/bin/servitor-send-file /usr/local/bin/servitor-action

USER agent
WORKDIR /home/agent/workspace

ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
